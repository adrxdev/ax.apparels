<div class="cart-page">
  <div class="container">
    <h1>Shopping Cart</h1>
    
    {% if cart.item_count > 0 %}
      <form action="/cart" method="post" class="cart-form">
        <div class="cart-items">
          {% for item in cart.items %}
            <div class="cart-item">
              <div class="item-image">
                <img src="{{ item.image | img_url: '200x' }}" alt="{{ item.title }}">
              </div>
              <div class="item-details">
                <h3>{{ item.product.title }}</h3>
                <p>{{ item.variant.title }}</p>
                <p class="item-price">{{ item.price | money }}</p>
              </div>
              <div class="item-quantity">
                <input type="number" name="updates[]" value="{{ item.quantity }}" min="0">
              </div>
              <div class="item-total">
                <p>{{ item.line_price | money }}</p>
              </div>
            </div>
          {% endfor %}
        </div>
        
        <div class="cart-footer">
          <div class="cart-summary">
            <p class="cart-subtotal">
              <span>Subtotal:</span>
              <span>{{ cart.total_price | money }}</span>
            </p>
            <button type="submit" class="btn btn-secondary">Update Cart</button>
            <button type="submit" name="checkout" class="btn btn-primary">Checkout</button>
          </div>
        </div>
      </form>
    {% else %}
      <div class="empty-cart">
        <p>Your cart is empty</p>
        <a href="/collections/all" class="btn btn-primary">Continue Shopping</a>
      </div>
    {% endif %}
    
  </div>
</div>
